{
  "parser_version": "1.2.0",
  "supported_fields": [
    "date", "measurement_time", "rmssd", "mean_hr", "readiness",
    "sdnn", "pns_index", "sns_index", "stress_index", "mean_rr_ms",
    "poincare_sd1_ms", "poincare_sd2_ms", "respiratory_rate_bpm",
    "lf_power_ms2", "hf_power_ms2", "lf_power_nu", "hf_power_nu",
    "lf_hf_ratio", "physiological_age", "measurement_quality", "mood_code",
    "recovery_status", "artefact_correction", "measurement_duration"
  ],
  "minimum_required_fields": ["date", "rmssd", "mean_hr"],
  "field_aliases": {
    "date": ["date", "measurement date", "measured"],
    "measurement_time": ["time", "measurement time", "measured at"],
    "rmssd": ["rmssd", "rms-sd"],
    "mean_hr": ["mean hr", "mean heart rate", "average heart rate", "avg hr"],
    "readiness": ["readiness", "readiness score", "readiness status"],
    "sdnn": ["sdnn"],
    "pns_index": ["pns index", "parasympathetic nervous system index"],
    "sns_index": ["sns index", "sympathetic nervous system index"],
    "stress_index": ["stress index"],
    "mean_rr_ms": ["mean rr", "mean rr ms"],
    "poincare_sd1_ms": ["poincare sd1", "poincaré sd1"],
    "poincare_sd2_ms": ["poincare sd2", "poincaré sd2"],
    "respiratory_rate_bpm": ["respiratory rate", "respiration rate"],
    "lf_power_ms2": ["lf power"], "hf_power_ms2": ["hf power"],
    "lf_power_nu": ["lf power n.u."], "hf_power_nu": ["hf power n.u."],
    "lf_hf_ratio": ["lf/hf ratio", "lf hf ratio"],
    "physiological_age": ["physiological age"],
    "measurement_quality": ["measurement quality", "quality"],
    "mood_code": ["mood"],
    "recovery_status": ["recovery status", "recovery"],
    "artefact_correction": ["artefact correction", "artifact correction", "corrected beats"],
    "measurement_duration": ["measurement duration", "duration"]
  },
  "expected_units": {
    "rmssd": ["ms"], "mean_hr": ["bpm"], "sdnn": ["ms"],
    "mean_rr_ms": ["ms"], "poincare_sd1_ms": ["ms"], "poincare_sd2_ms": ["ms"],
    "respiratory_rate_bpm": ["breaths/min"], "lf_power_ms2": ["ms²"],
    "hf_power_ms2": ["ms²"], "lf_power_nu": ["%"], "hf_power_nu": ["%"],
    "physiological_age": ["years"],
    "artefact_correction": ["%"], "measurement_duration": ["s", "sec", "min"]
  },
  "valid_ranges": {
    "rmssd": [0.1, 1000.0], "mean_hr": [20.0, 250.0],
    "readiness": [0.0, 100.0], "sdnn": [0.1, 1000.0],
    "pns_index": [-20.0, 20.0], "sns_index": [-20.0, 20.0],
    "stress_index": [0.0, 10000.0], "artefact_correction": [0.0, 100.0],
    "measurement_duration": [1.0, 7200.0], "mean_rr_ms": [100.0, 3000.0],
    "poincare_sd1_ms": [0.1, 1000.0], "poincare_sd2_ms": [0.1, 2000.0],
    "respiratory_rate_bpm": [1.0, 80.0], "lf_power_ms2": [0.0, 10000000.0],
    "hf_power_ms2": [0.0, 10000000.0], "lf_power_nu": [0.0, 100.0],
    "hf_power_nu": [0.0, 100.0], "lf_hf_ratio": [0.0, 1000.0],
    "physiological_age": [1.0, 130.0]
  },
  "auto_accept_threshold": 0.9,
  "manual_review_threshold": 0.6,
  "reject_threshold": 0.35,
  "date_formats": ["%Y-%m-%d", "%Y/%m/%d", "%d.%m.%Y", "%d/%m/%Y", "%b %d, %Y", "%B %d, %Y"],
  "time_formats": ["%H:%M:%S", "%H:%M", "%I:%M %p"],
  "supported_extensions": [".png", ".jpg", ".jpeg", ".heic", ".webp"],
  "image_preprocessing_defaults": {
    "grayscale": true, "autocontrast": true, "scale": 2.0,
    "median_filter_size": 3
  },
  "source_priority": ["csv", "reviewed_screenshot_ocr", "manual"]
}
